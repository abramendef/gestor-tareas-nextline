generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  completed   Boolean  @default(false)
  dueDate     String
  comments    String?
  responsible String?
  tags        String?  // Almacenado como string delimitado por comas (SQLite no soporta scalar lists)
  userId      String   // Validacion obligatoria requerida por el backend
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
